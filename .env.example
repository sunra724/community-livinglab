NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional for server-side admin dashboard reads.
# Keep this key server-only and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required in production to unlock /admin write actions.
ADMIN_ACCESS_CODE=change-this-admin-code
